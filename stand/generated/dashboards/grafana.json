      "id": 1,
      "type": "row",
      "title": "Контейнерные метрики (cAdvisor)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "container cpu usage",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(container_cpu_usage_seconds_total{job=\"cadvisor\",service=\"$job\"}[5m]))"
        }
      ],
      "options": {},
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
